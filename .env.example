# --- Neon (Postgres serverless) ---
# Récupère cette URL sur https://console.neon.tech après création du projet.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/faith_re?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# `openssl rand -base64 32` pour un secret fort
AUTH_SECRET="change-me-in-production"

# Discord OAuth — créer une appli sur https://discord.com/developers/applications
# Callback URL à configurer côté Discord : http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Privilèges MJ ---
# Discord User ID du MJ. Reçoit le rôle "mj" automatiquement au signup.
# Trouver son ID : Discord → Paramètres → Avancés → Mode développeur, puis clic droit sur son profil.
MJ_DISCORD_ID=""
